# UMA-Agent environment variables
# Copy to .env and adjust as needed

KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=test-realm
CLIENT_ID=resource-server
CLIENT_SECRET=uma-resource-server-secret

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=keycloak
POSTGRES_USER=keycloak
POSTGRES_PASSWORD=keycloak_password

# HMAC secret for delegation chain claim signing
# Change in production — all resource servers in a deployment must share this value
CHAIN_HMAC_SECRET=uma-agent-chain-hmac-secret-2024

MAX_DELEGATION_DEPTH=4

# OpenAI API key (required for LLM agent integration, step 4)
OPENAI_API_KEY=

# Anthropic API key (alternative LLM backend)
ANTHROPIC_API_KEY=
